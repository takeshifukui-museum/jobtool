{
  "name": "ai-text-editor",
  "version": "0.2.0",
  "description": "AI付きテキストエディタ — メモ帳感覚で書き、右にAI応答を置いて推敲できる",
  "main": "dist/main.js",
  "scripts": {
    "build:main": "tsc",
    "build:renderer": "esbuild renderer/renderer.ts --bundle --platform=browser --outfile=dist/renderer/renderer.js --sourcemap",
    "build": "npm run build:main && npm run build:renderer",
    "dev": "npm run build && electron .",
    "start": "electron ."
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.2.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "markdown-it": "^14.1.0"
  }
}
